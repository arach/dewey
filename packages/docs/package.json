{
  "name": "@arach/dewey",
  "version": "0.3.7",
  "description": "Documentation toolkit for AI-agent-ready docs — audit, score, generate AGENTS.md/llms.txt/docs.json, and optionally publish a static site",
  "homepage": "https://dewey.arach.dev",
  "bugs": {
    "url": "https://github.com/arach/dewey/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dewey": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css": {
      "style": "./dist/css/index.css",
      "default": "./dist/css/index.css"
    },
    "./css/tailwind": {
      "style": "./dist/css/tailwind.css",
      "default": "./dist/css/tailwind.css"
    },
    "./css/tokens": {
      "style": "./dist/css/tokens.css",
      "default": "./dist/css/tokens.css"
    },
    "./css/base.css": {
      "style": "./dist/css/base.css",
      "default": "./dist/css/base.css"
    },
    "./css/colors/neutral.css": {
      "style": "./dist/css/colors/neutral.css",
      "default": "./dist/css/colors/neutral.css"
    },
    "./css/colors/ocean.css": {
      "style": "./dist/css/colors/ocean.css",
      "default": "./dist/css/colors/ocean.css"
    },
    "./css/colors/emerald.css": {
      "style": "./dist/css/colors/emerald.css",
      "default": "./dist/css/colors/emerald.css"
    },
    "./css/colors/purple.css": {
      "style": "./dist/css/colors/purple.css",
      "default": "./dist/css/colors/purple.css"
    },
    "./css/colors/dusk.css": {
      "style": "./dist/css/colors/dusk.css",
      "default": "./dist/css/colors/dusk.css"
    },
    "./css/colors/rose.css": {
      "style": "./dist/css/colors/rose.css",
      "default": "./dist/css/colors/rose.css"
    },
    "./css/colors/github.css": {
      "style": "./dist/css/colors/github.css",
      "default": "./dist/css/colors/github.css"
    },
    "./css/colors/warm.css": {
      "style": "./dist/css/colors/warm.css",
      "default": "./dist/css/colors/warm.css"
    },
    "./css/colors/midnight.css": {
      "style": "./dist/css/colors/midnight.css",
      "default": "./dist/css/colors/midnight.css"
    },
    "./css/colors/editorial.css": {
      "style": "./dist/css/colors/editorial.css",
      "default": "./dist/css/colors/editorial.css"
    },
    "./css/colors/mono.css": {
      "style": "./dist/css/colors/mono.css",
      "default": "./dist/css/colors/mono.css"
    },
    "./css/colors/hudson.css": {
      "style": "./dist/css/colors/hudson.css",
      "default": "./dist/css/colors/hudson.css"
    },
    "./styles": {
      "style": "./dist/css/index.css",
      "default": "./dist/css/index.css"
    },
    "./tailwind": {
      "import": "./dist/tailwind/preset.js",
      "types": "./dist/tailwind/preset.d.ts"
    },
    "./agent-artifacts": {
      "import": "./dist/cli/agent-artifacts.js",
      "types": "./dist/cli/agent-artifacts.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "build": "bun run typecheck && vite build && tsup src/cli/index.ts src/cli/agent-artifacts.ts --format esm --dts --out-dir dist/cli && tsup src/tailwind/preset.ts --format esm --dts --out-dir dist/tailwind",
    "clean": "rm -rf dist",
    "lint": "bun run typecheck",
    "test": "bun test test/*.test.ts",
    "test:visual": "playwright test",
    "verify:package": "bun scripts/verify-package.ts",
    "verify:release": "bun scripts/verify-release-version.ts"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "clsx": "^2.1.1",
    "commander": "^15.0.0",
    "cosmiconfig": "^9.0.2",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.22.0",
    "react-markdown": "^10.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.1",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3"
  },
  "keywords": [
    "documentation",
    "docs",
    "cli",
    "react",
    "components",
    "agents",
    "llm",
    "markdown"
  ],
  "author": "Arach Tchoupani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arach/dewey"
  }
}
